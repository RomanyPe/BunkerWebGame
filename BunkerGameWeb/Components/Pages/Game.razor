@page "/"
@using BunkerGameWeb.Models
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject NavigationManager Navigation
@inject ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Бункер - Игра</PageTitle>

<div class="bunker-panel p-3 rounded shadow">
    <h1 class="mb-4">🌍 Катастрофа: @CurrentCatastrophe</h1>

    @if (CurrentPlayer != null)
    {
        @* --- БЛОК ЛОББИ (До старта игры) --- *@
        @if (!GameManager.IsGameStarted)
        {
            <div class="d-flex align-items-center gap-3 mb-4 p-3 border rounded shadow-sm"
                 style="background-color: #151515; border-color: #333 !important;">
                
                <button class="btn @(CurrentPlayer.IsReady ? "btn-success" : "btn-outline-warning")"
                        disabled="@GameManager._isStarting"
                        @onclick="() => GameManager.ToggleReady(MyId)">
                    @(GameManager._isStarting ? "Запуск..." : (CurrentPlayer.IsReady ? "Я готов!" : "Нажать готовность"))
                </button>

                @if (GameManager.AreAllReady && !GameManager._isStarting)
                {
                    <span class="badge bg-success">Все готовы!</span>
                }
                else
                {
                    <small style="color: #ffc107;">Ожидание: @GameManager.ArrayPlayers.Count(p => p.IsReady) / @GameManager.ArrayPlayers.Count</small>
                }

                @if (GameManager.ArrayPlayers.FirstOrDefault()?.Id == MyId)
                {
                    <button class="btn btn-danger ms-auto"
                            disabled="@(!GameManager.AreAllReady || GameManager._isStarting)"
                            @onclick="HandleStartClick">
                        ЗАПУСТИТЬ БУНКЕР
                    </button>
                }
            </div>

            @* Список игроков в лобби *@
            <div class="d-inline-flex flex-column gap-2 p-3 border rounded mb-4" style="background-color: #151515; border-color: #333; min-width: 300px;">
                <h5 class="text-center border-bottom pb-2" style="color: #ffc107;">Список игроков</h5>
                @foreach (var player in GameManager.ArrayPlayers)
                {
                    <div class="d-flex justify-content-between align-items-center p-2 rounded border"
                         style="background-color: #1a1a1a; border-color: #333; color: #ffc107;">
                        <span>@player.Name @(player.Id == MyId ? "(Вы)" : "")</span>
                        <span class="badge @(player.IsReady ? "bg-success" : "bg-secondary")">@(player.IsReady ? "Готов" : "Ждет")</span>
                    </div>
                }
            </div>
        }

        @* --- БЛОК ИГРЫ (После старта) --- *@
        @if (GameManager.IsGameStarted)
        {
            <div class="game-header d-flex gap-3 align-items-start mb-4">
                @* Плашка раунда *@
                <div class="p-2 border rounded shadow-sm d-flex flex-column justify-content-center align-items-center"
                     style="width: 120px; height: 90px; background-color: #151515; border-color: #444; border-width: 2px;">
                    <span style="color: #888; font-size: 0.7rem; text-transform: uppercase;">Раунд</span>
                    <p class="mb-0" style="color: #ffc107; font-size: 1.8rem; font-weight: bold;">@GameManager.GameRounds</p>
                    @if (GameManager.IsVotingActive)
                    {
                        <span class="badge bg-danger" style="font-size: 0.5rem;">ГОЛОСОВАНИЕ</span>
                    }
                </div>

                @* Инфо-панель хода *@
                <div class="flex-grow-1">
                    @if (MyId == GameManager.CurrentTurnPlayerId)
                    {
                        <div class="p-3 border rounded shadow-sm" style="background-color: #1a2e1a; border-color: #2d5a2d; color: #d4edda;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h4 class="mb-1" style="color: #75ec75;">Ваш ход!</h4>
                                    <p class="mb-0">Выберите карточки: <strong>@CurrentPlayer.CurrentOpenedCard из @CurrentPlayer.CountNeedOpen</strong></p>
                                </div>
                                @if (CurrentPlayer.CurrentOpenedCard == CurrentPlayer.CountNeedOpen)
                                {
                                    <button class="btn btn-success px-4 fw-bold" @onclick="ConfirmTurn">ПОДТВЕРДИТЬ</button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="p-3 border rounded shadow-sm" style="background-color: #2b2111; border-color: #554121; color: #ffeeba;">
                            <h4 class="mb-1" style="color: #ffc107;">Ходит @(GameManager.ArrayPlayers.FirstOrDefault(p => p.Id == GameManager.CurrentTurnPlayerId)?.Name ?? "...")</h4>
                            <p class="mb-0">Ожидайте завершения хода.</p>
                        </div>
                    }
                </div>
            </div>

            @* Панель голосования *@
            @if (GameManager.IsVotingActive)
            {
                <div class="p-4 border rounded mb-4 shadow" style="background-color: #1a1515; border-color: #8b0000 !important;">
                    <h3 class="text-center mb-3" style="color: #ff4500;">🚨 ГОЛОСОВАНИЕ 🚨</h3>
                    @if (GameManager.Votes.ContainsKey(MyId))
                    {
                        <div class="text-center text-muted">Голос принят. Ожидание: @GameManager.Votes.Count / @GameManager.ArrayPlayers.Count(p => !p.IsEliminated)</div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                            @foreach (var player in GameManager.ArrayPlayers.Where(p => !p.IsEliminated))
                            {
                                <button class="btn btn-outline-danger" @onclick="() => GameManager.SubmitVote(MyId, player.Id)">Изгнать @player.Name</button>
                            }
                        </div>
                    }
                </div>
            }

            @* СЕТКА КАРТОЧЕК *@
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var player in GameManager.ArrayPlayers)
                {
                    <div class="col">
                        <div class="character-card h-100 @(player.Id == MyId ? "my-card" : "") @(player.IsEliminated ? "eliminated" : "") @(player.Id == GameManager.CurrentTurnPlayerId ? "active-turn" : "")">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span class="player-name">@player.Name @(player.Id == MyId ? "(ВЫ)" : "")</span>
                                @if (player.IsEliminated)
                                {
                                    <span class="badge bg-danger">ИЗГНАН</span>
                                }
                            </div>
                            <div class="card-body p-0">
                                <div class="trait-group">
                                    <div class="group-title">Личность</div>
                                    @renderTrait(PlayerFieldType.BiologicalSex, "Пол", player.BiologicalSex.IsOpened, player.Id, GameManager.ConfigCharacterBiologicalSex.Text[player.BiologicalSex.NameTrait])
                                    @renderTrait(PlayerFieldType.Age, "Возраст", player.Age.IsOpened, player.Id, $"{player.Age.Amount} лет. ({GameManager.ConfigCharacterAge.Text[player.Age.NameTrait]})")
                                    @renderTrait(PlayerFieldType.BodyBuild, "Тело", player.BodyBuild.IsOpened, player.Id, GameManager.ConfigCharacterBodyBuild.Text[player.BodyBuild.NameTrait])
                                    @renderTrait(PlayerFieldType.Reproduction, "Репродукция", player.Reproduction.IsOpened, player.Id, $"{GameManager.ConfigCharacterReproduction.Text[player.Reproduction.NameTrait]} ({player.Reproduction.FinalAmount}%)")
                                </div>
                                <div class="trait-group">
                                    <div class="group-title">Профессия и навыки</div>
                                    @renderTrait(PlayerFieldType.Profession, "Профессия", player.Profession.IsOpened, player.Id, GameManager.ConfigCharacterProfession.Text[player.Profession.NameTrait])
                                    @renderTrait(PlayerFieldType.Knowledge, "Знания", player.Knowledge.IsOpened, player.Id, $"{GameManager.ConfigCharacterKnowledge.Text[player.Knowledge.NameTrait]} ({player.Knowledge.FinalAmount} лет.)")
                                    @renderTrait(PlayerFieldType.Hobby, "Хобби", player.Hobby.IsOpened, player.Id, GameManager.ConfigCharacterHobby.Text[player.Hobby.NameTrait])
                                    @renderTrait(PlayerFieldType.Trait, "Черта", player.Trait.IsOpened, player.Id, GameManager.ConfigCharacterTrait.Text[player.Trait.NameTrait])
                                </div>
                                <div class="trait-group">
                                    <div class="group-title">Состояние</div>
                                    @renderTrait(PlayerFieldType.Health, "Здоровье", player.Health.IsOpened, player.Id, GameManager.ConfigCharacterHealth.Text[player.Health.NameTrait])
                                    @renderTrait(PlayerFieldType.Phobia, "Фобия", player.Phobia.IsOpened, player.Id, GameManager.ConfigCharacterPhobia.Text[player.Phobia.NameTrait])
                                    @renderTrait(PlayerFieldType.Secret, "Секрет", player.Secret.IsOpened, player.Id, GameManager.ConfigCharacterSecret.Text[player.Secret.NameTrait])
                                </div>
                                <div class="trait-group">
                                    <div class="group-title">Багаж и Инфо</div>
                                    @renderTrait(PlayerFieldType.Inventory, "Багаж", player.Inventory.IsOpened, player.Id, GameManager.ConfigCharacterInventory.Text[player.Inventory.NameTrait])
                                    @renderTrait(PlayerFieldType.AdditionalInformation, "Доп. инфо", player.AdditionalInformation.IsOpened, player.Id, GameManager.ConfigCharacterAdditionalInformation.Text[player.AdditionalInformation.NameTrait])
                                    @renderTrait(PlayerFieldType.SpecialCondition, "Спец. карта", player.SpecialCondition.IsOpened, player.Id, GameManager.ConfigCharacterSpecialCondition.Text[player.SpecialCondition.NameTrait])
                                    @renderTrait(PlayerFieldType.Relation, "Отношение", player.Relation.IsOpened, player.Id, GameManager.ConfigCharacterRelation.Text[player.Relation.NameTrait])
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (GameManager.IsGameStarted && CurrentPlayer != null && !CurrentPlayer.SpecialCondition.IsUsed)
                {
                    <div class="p-3 border rounded mb-3" style="background-color: #1a1515; border-color: #8b0000;">
                        <h5 style="color: #ff4500;">🎯 Специальное умение</h5>
                        <p class="mb-2">@GameManager.ConfigCharacterSpecialCondition.Text[CurrentPlayer.SpecialCondition.NameTrait]</p>
                        <button class="btn btn-outline-warning btn-sm" @onclick="() => Open(PlayerFieldType.SpecialCondition, MyId)">
                            Использовать умение
                        </button>
            </div>
        }
            </div>
    }
    }
    @if (MyId == GameManager.ArrayPlayers.FirstOrDefault()?.Id)
    {
        <button class="btn btn-outline-danger btn-sm" @onclick="HandleRestart">
            ⚙️ Полный рестарт сервера
        </button>
    }


</div>

@code {
    // Рендеринг строки характеристики (Вместо ячейки таблицы)
    RenderFragment renderTrait(PlayerFieldType type, string label, bool isOpened, int playerId, string value) => __builder =>
    {
        bool showValue = isOpened || playerId == MyId;
        // Можно кликнуть, если: не открыто И не я И мой ход И не голосование
        bool canClick = !isOpened && playerId == MyId && GameManager.CurrentTurnPlayerId == MyId && !GameManager.IsVotingActive;

        <div class="trait-row @(showValue ? "opened" : "locked") @(canClick ? "clickable" : "")"
             @onclick="() => { if (canClick) Open(type, playerId); }">
            <span class="trait-label">@label:</span>
            <span class="trait-value">
                @if (showValue)
                {
                    @((MarkupString)value)
                }
                else
                {

                    <span class="lock-icon">🔒</span>
                }
            </span>
        </div>
    };

Ы}
